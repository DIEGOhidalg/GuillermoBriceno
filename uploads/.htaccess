# Bloquear ejecución de scripts en la carpeta de uploads
# Impide que archivos subidos puedan ejecutarse como PHP u otros scripts

php_flag engine off
Options -ExecCGI
RemoveHandler .php .php3 .php4 .php5 .php7 .php8 .phtml .phar .pl .py .sh .cgi

<FilesMatch "(?i)\.(php|php3|php4|php5|php7|php8|phtml|phar|pl|py|sh|cgi)$">
    Require all denied
</FilesMatch>
